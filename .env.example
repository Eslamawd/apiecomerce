APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -------------------------------------------------------
# Next.js / Frontend Integration
# -------------------------------------------------------
# The URL of the Next.js frontend (used for CORS allow-list)
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000

# For Bearer token mode set false, for cookie/session mode set true
CORS_SUPPORTS_CREDENTIALS=false

# Sanctum: comma-separated list of stateful domains (SPA mode)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000

# Demo import defaults
DEMO_VENDOR_EMAIL=demo-vendor@example.com
DEMO_VENDOR_NAME="Demo Vendor"
DEMO_FALLBACK_VIDEO_URL=https://samplelib.com/lib/preview/mp4/sample-5s.mp4

# Auto-promote this email to admin role on register/seed
ADMIN_EMAIL=admin@example.com
